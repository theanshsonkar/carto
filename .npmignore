# Generated files — never ship these
.carto/
AGENTS.md
mcp.md
CARTO_BRAIN.md
BENCHMARK_RESULTS.md
CARTO_SCALE_REPORT.md
CARTO_V2_ARCHITECTURE.md

# Git config — not needed at npm install time
.gitattributes
.gitignore

# GitHub Action — repo-root artifact, not part of the npm package
action.yml

# Internal specs and notes
KIRO_SPEC*.md
PROGRESS.md
Progress/
CARTO_PLAN.md

# Marketing site — not part of the npm package (huge; has its own node_modules/build)
carto-site/
carto-site-v2/

# Tests
test/

# Internal benchmarks (validation harness, not user-facing)
bench/

# Dev tools
.kiro/
.claude/

# Dogfood MCP wiring (only useful when you clone this repo)
.mcp.json
.vscode/
.github/
.npmrc
.DS_Store
*.log
*.tmp

# npm pack output — don't ship a previous tarball inside the new one
*.tgz
